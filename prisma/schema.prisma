generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id              Int            @id @default(autoincrement())
  sector          String
  interno         String?
  categoryId      Int
  category        Category       @relation(fields: [categoryId], references: [id])
  ubicacion       String   
  usuarioSolicita String 
  descripcion     String
  esGuardia       Boolean        @default(false)
  estado          Estado         @default(EN_PROCESO) 
  fechaCreacion   DateTime       @default(now())
  fechaCierre     DateTime?
  tecnico         String
  tecnicoCierre   String?
  logs            TicketLog[]
  urgencia        Urgencia       @default(BAJA)
  tipoAsistencia  TipoAsistencia @default(PRESENCIAL)
  solucion        String?
  destacado       Boolean        @default(false)
}

model TicketLog {
  id       Int      @id @default(autoincrement())
  ticketId Int
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  estado   Estado   
  tecnico  String   
  fecha    DateTime @default(now())
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  tickets Ticket[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  nombre    String
  rol       String   @default("TECNICO") // "ADMIN" o "TECNICO"
  createdAt DateTime @default(now())
}

enum Estado {
  CREADO
  EN_PROCESO
  PAUSADO
  REANUDADO
  EDITADO
  RESUELTO
  ELIMINADO
}

enum Urgencia {
  BAJA
  MEDIA
  CRITICA
}

enum TipoAsistencia {
  PRESENCIAL
  REMOTA
}