generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id               Int      @id @default(autoincrement())
  sector           String
  interno          String?
  categoryId       Int
  category         Category @relation(fields: [categoryId], references: [id])
  ubicacion        String   
  usuario_solicita String 
  descripcion      String
  es_guardia       Boolean  @default(false)
  estado           String   @default("EN_PROCESO") 
  fecha_creacion   DateTime @default(now())
  fecha_cierre     DateTime?
  tecnico          String
  tecnico_cierre   String?
  logs             TicketLog[]
  urgencia         Urgencia       @default(BAJA)
  tipo_asistencia  TipoAsistencia @default(PRESENCIAL)
}

model TicketLog {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  estado      String   
  tecnico     String   
  fecha       DateTime @default(now())
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  tickets Ticket[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  nombre    String
  rol       String   @default("TECNICO") // "ADMIN" o "TECNICO"
  createdAt DateTime @default(now())
}

enum Urgencia {
  BAJA
  MEDIA
  CRITICA
}

enum TipoAsistencia {
  PRESENCIAL
  REMOTA
}